@page "/comprar/{EventoId}/ingressos"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject PurchaseStateService PurchaseState
@using System.Net.Http.Headers

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-2">
    <PurchaseStepper ActiveStep="0" />

    <div class="d-flex align-center mb-4 flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h5">Escolha seus assentos</MudText>
            @if (!string.IsNullOrEmpty(_nomeEvento))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_nomeEvento</MudText>
            }
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/">
            Voltar
        </MudButton>
    </div>

    @if (_carregando)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-16">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Color="Color.Secondary" Class="mt-4">Carregando mapa de assentos...</MudText>
        </MudStack>
    }
    else if (!_assentos.Any())
    {
        <MudAlert Severity="Severity.Info">Nenhum ingresso disponível para este evento.</MudAlert>
    }
    else
    {
        <SeatMap Title="Mapa do auditório"
                 Subtitle="@_subtituloMapa"
                 Seats="_assentos"
                 ShowSectorFilter="@_mostrarFiltroSetor"
                 OnCheckout="OnCheckout" />
    }
</MudContainer>

@code {
    [Parameter] public string EventoId { get; set; } = "";

    private List<SeatModel> _assentos = [];
    private bool _carregando = true;
    private string _nomeEvento = "";
    private string _subtituloMapa = "";
    private bool _mostrarFiltroSetor = true;
    private EventoViewModel? _evento;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
        {
            NavManager.NavigateTo($"/login?returnUrl=/comprar/{EventoId}/ingressos");
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        try
        {
            _evento = await Http.GetFromJsonAsync<EventoViewModel>($"api/Evento/{EventoId}");
            if (_evento != null)
            {
                _nomeEvento = _evento.Nome;
                _subtituloMapa = string.IsNullOrWhiteSpace(_evento.Local)
                    ? _evento.DataEvento.ToString("dd/MM/yyyy HH:mm")
                    : $"{_evento.DataEvento:dd/MM/yyyy HH:mm} · {_evento.Local}";
                _mostrarFiltroSetor = _evento.Tipo == 0;
            }

            var ingressos = await Http.GetFromJsonAsync<List<IngressoResponseDTO>>($"api/Ingresso/eventos/{EventoId}/ingressos");
            _assentos = ingressos is { Count: > 0 }
                ? SeatMapMapper.FromIngressos(ingressos)
                : [];
        }
        catch
        {
            Snackbar.Add("Erro ao carregar ingressos.", Severity.Error);
        }
        finally
        {
            _carregando = false;
            StateHasChanged();
        }
    }

    private Task OnCheckout(IReadOnlyList<SeatModel> selected)
    {
        if (!Guid.TryParse(EventoId, out var eventoGuid))
        {
            Snackbar.Add("Evento inválido.", Severity.Error);
            return Task.CompletedTask;
        }

        var states = selected.Select(s => new SelectedSeatState(
            s.IngressoId,
            s.DisplayLabel,
            s.Setor,
            s.Price,
            s.DisplayLabel)).ToList();

        PurchaseState.SetSelection(eventoGuid, states);
        NavManager.NavigateTo($"/checkout/{EventoId}");
        return Task.CompletedTask;
    }
}
