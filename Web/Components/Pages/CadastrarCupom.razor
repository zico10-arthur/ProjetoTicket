@page "/cupons/novo"
@rendermode InteractiveServer
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudText Typo="Typo.h5" GutterBottom="true">Novo Cupom de Desconto</MudText>
    
    <MudPaper Class="pa-4">
        <MudTextField @bind-Value="model.Codigo" Label="Código (ex: PROMO10)" Variant="Variant.Outlined" Margin="Margin.Dense" />
        
        <MudNumericField @bind-Value="model.PorcentagemDesconto" Label="Desconto (%)" Variant="Variant.Outlined" Step="1" Class="mt-4" />
        
        <MudNumericField @bind-Value="model.ValorMinimo" Label="Valor Mínimo para Uso" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="R$" Class="mt-4" />

        @* NOVO: Campo de Data *@
        <MudDatePicker Label="Data de Expiração" @bind-Date="model.DataExpiracao" Variant="Variant.Outlined" Class="mt-4" />

        @* NOVO: Campo para ID do Evento (Opcional) *@
        <MudTextField @bind-Value="model.IdEvento" Label="ID do Evento (Opcional)" HelperText="Deixe vazio para cupom global" Class="mt-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6" OnClick="EnviarCadastro">
            Cadastrar Cupom
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private CadastrarCupomDTO model = new() { 
        DataExpiracao = DateTime.Now.AddDays(30) // Sugere uma semana de validade
    };

    private async Task EnviarCadastro()
    {
        try 
        {
            var response = await Http.PostAsJsonAsync("api/cupom", model);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Cupom criado com sucesso!", Severity.Success);
                model = new(); // Limpa a tela
            }
            else
            {
                // ISSO VAI MOSTRAR O ERRO REAL NA TELA PARA VOCÊ:
                var erroDetalhado = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"ERRO DA API: {erroDetalhado}");
                Snackbar.Add($"Erro: {erroDetalhado}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha de conexão: {ex.Message}", Severity.Error);
        }
    }
}