@page "/demo/assentos"
@rendermode InteractiveServer
@using Web.Mock
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4" Icon="@Icons.Material.Filled.TheaterComedy">
        <b>Modo demonstração</b> — dados mockados. Não é necessário API, login nem banco de dados.
    </MudAlert>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6">@TicketPrimeMockData.EventoUnifesoNome</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            15/12/2026 · 19:00 · Auditório Campus Quinta — UNIFESO
        </MudText>

        <MudSelect T="MockCenarioAssentos"
                   Label="Cenário de ocupação (mock)"
                   Value="_cenario"
                   ValueChanged="AlterarCenario"
                   Class="mt-4"
                   Style="max-width:320px;">
            <MudSelectItem Value="MockCenarioAssentos.Padrao">Padrão (alguns ocupados)</MudSelectItem>
            <MudSelectItem Value="MockCenarioAssentos.MuitosLivres">Quase vazio</MudSelectItem>
            <MudSelectItem Value="MockCenarioAssentos.QuaseLotado">Quase lotado</MudSelectItem>
        </MudSelect>
    </MudPaper>

    <SeatMap Title="Escolha seus assentos"
             Subtitle="Auditório Campus Quinta — UNIFESO (simulação)"
             Seats="_seats"
             OnCheckout="OnCheckout" />

    <MudButton Variant="Variant.Text"
               Color="Color.Secondary"
               Href="/"
               Class="mt-4">
        Voltar ao início
    </MudButton>
</MudContainer>

@code {
    private MockCenarioAssentos _cenario = MockCenarioAssentos.Padrao;
    private List<SeatModel> _seats = TicketPrimeMockData.GetAssentos();

    private void AlterarCenario(MockCenarioAssentos cenario)
    {
        _cenario = cenario;
        _seats = TicketPrimeMockData.GetAssentos(cenario);
    }

    private Task OnCheckout(IReadOnlyList<SeatModel> selected)
    {
        var labels = string.Join(", ", selected.Select(s => s.DisplayLabel));
        var total = selected.Sum(s => s.Price);
        Snackbar.Add(
            $"[Mock] {selected.Count} assento(s): {labels} — Total {total:C}",
            Severity.Success);
        return Task.CompletedTask;
    }
}
