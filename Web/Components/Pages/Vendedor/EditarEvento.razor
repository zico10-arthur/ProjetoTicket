@page "/eventos/editar/{Id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<AuthorizeView Roles="Vendedor">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudText Typo="Typo.h5" Class="mb-6">Editar Evento</MudText>

            @if (dto is null)
            {
                <MudText>Carregando...</MudText>
            }
            else
            {
                <MudTextField @bind-Value="dto.Nome" Label="Nome" Variant="Variant.Outlined" Class="mb-4" />
                <MudSelect T="int" @bind-Value="dto.Tipo" Label="Tipo" Variant="Variant.Outlined" Class="mb-4">
                    <MudSelectItem Value="0">Teatro</MudSelectItem>
                    <MudSelectItem Value="1">Palestra</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="dto.Local" Label="Local" Variant="Variant.Outlined" Class="mb-4" />
                <MudTextField @bind-Value="dto.Descricao" Label="Descrição" Variant="Variant.Outlined" Class="mb-4" Lines="3" />
                <MudTextField @bind-Value="dto.CapacidadeTotal" Label="Capacidade Total" Variant="Variant.Outlined" Class="mb-4" InputType="InputType.Number" />
                <MudDatePicker @bind-Date="dataEvento" Label="Data do Evento" Variant="Variant.Outlined" Class="mb-4" />
                <MudTimePicker @bind-Time="horaEvento" Label="Horário" Variant="Variant.Outlined" Class="mb-4" AmPm="false" />

                <MudSwitch @bind-Value="_gratuito" Label="Evento gratuito" Color="Color.Secondary" Class="mb-4" />

                @if (!_gratuito)
                {
                    <MudNumericField T="decimal" @bind-Value="dto.PrecoPadrao" Label="Preço (R$)" Variant="Variant.Outlined" Class="mb-6" Format="F2" Min="0m" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Class="mb-6">Ingressos gratuitos — preço será R$ 0,00.</MudAlert>
                }

                <div class="d-flex gap-3">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/eventos/meus">Cancelar</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar">Salvar</MudButton>
                </div>
            }
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
            <MudAlert Severity="Severity.Warning">Você precisa estar logado como Vendedor para acessar esta página.</MudAlert>
            <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Ir para Login</MudButton>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid Id { get; set; }

    private EventoRequestDTO? dto;
    private DateTime? dataEvento;
    private TimeSpan? horaEvento;
    private bool _gratuito;

    protected override async Task OnInitializedAsync()
    {
        var evento = await Http.GetFromJsonAsync<EventoViewModel>($"api/Evento/{Id}");
        if (evento is null)
        {
            Snackbar.Add("Evento não encontrado.", Severity.Error);
            NavManager.NavigateTo("/eventos/meus");
            return;
        }

        _gratuito = evento.IsGratuito;

        dto = new EventoRequestDTO
        {
            Nome = evento.Nome,
            CapacidadeTotal = evento.CapacidadeTotal,
            PrecoPadrao = evento.PrecoPadrao,
            DataEvento = evento.DataEvento,
            Tipo = evento.Tipo,
            Local = evento.Local,
            Descricao = evento.Descricao
        };
        dataEvento = evento.DataEvento.Date;
        horaEvento = evento.DataEvento.TimeOfDay;
    }

    private async Task Salvar()
    {
        if (dto is null) return;

        if (dataEvento is null)
        {
            Snackbar.Add("Selecione a data do evento.", Severity.Warning);
            return;
        }

        dto.DataEvento = dataEvento.Value.Date + (horaEvento ?? TimeSpan.Zero);
        dto.PrecoPadrao = _gratuito ? 0 : dto.PrecoPadrao;

        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token!);

        var response = await Http.PutAsJsonAsync($"api/Evento/{Id}", dto);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Evento atualizado com sucesso!", Severity.Success);
            NavManager.NavigateTo("/eventos/meus");
        }
        else
        {
            var json = await response.Content.ReadAsStringAsync();
            var doc = System.Text.Json.JsonDocument.Parse(json);
            var mensagem = doc.RootElement.TryGetProperty("message", out var msg)
                ? msg.GetString() ?? "Erro ao salvar evento."
                : "Erro ao salvar evento.";
            Snackbar.Add(mensagem, Severity.Error);
        }
    }
}
