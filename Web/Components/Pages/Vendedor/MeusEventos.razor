@page "/eventos/meus"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject IJSRuntime JS

<AuthorizeView Roles="Vendedor">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-2">
            <MudText Typo="Typo.h4" Class="mb-6">Painel do Vendedor</MudText>

            @if (_carregando)
            {
                <MudGrid Class="mb-6">
                    @for (var i = 0; i < 3; i++)
                    {
                        <MudItem xs="12" sm="4">
                            <MudSkeleton Height="100px" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">Eventos</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@(_eventos?.Count ?? 0)</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">Ingressos vendidos</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@_vendas.Count(v => v.Pago && !v.Reembolsada)</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">Receita estimada</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary">
                                @_vendas.Where(v => v.Pago && !v.Reembolsada).Sum(v => v.ValorFinalPago).ToString("C")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }

            <div class="d-flex align-center mb-4">
                <MudText Typo="Typo.h6">Meus Eventos</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/eventos/criar" StartIcon="@Icons.Material.Filled.Add">
                    Novo evento
                </MudButton>
            </div>

            @if (_eventos is null)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (!_eventos.Any())
            {
                <MudPaper Class="pa-6 text-center" Outlined="true">
                    <MudText Class="mb-3">Nenhum evento cadastrado ainda.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/eventos/criar">Criar primeiro evento</MudButton>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3" Class="mb-8">
                    @foreach (var evento in _eventos)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="2">
                                <MudCardContent>
                                    <MudStack Row="true" Spacing="1" Class="mb-2">
                                    @if (evento.Cancelado)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Cancelado</MudChip>
                                    }
                                    <MudChip T="string" Size="Size.Small">@evento.TipoLabel</MudChip>
                                        @if (evento.IsGratuito)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">Gratuito</MudChip>
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.h6"><b>@evento.Nome</b></MudText>
                                    <MudText Typo="Typo.body2">@evento.DataEvento.ToString("dd/MM/yyyy HH:mm")</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Primary"><b>@evento.PrecoPadrao.ToString("C")</b></MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Size="Size.Small" Href="@($"/eventos/editar/{evento.Id}")">Editar</MudButton>
                                    <MudButton Size="Size.Small" Href="@($"/eventos/{evento.Id}/ingressos")">Ingressos</MudButton>
                                    @if (!evento.Cancelado)
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Error" OnClick="() => AbrirCancelamento(evento.Id)">
                                            Cancelar evento
                                        </MudButton>
                                    }
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }

            <MudPaper Class="pa-4 mb-8" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">Configurações da loja</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Edite nome, e-mail e senha no perfil. Logo, descrição e site da vitrine dependem do backend ST-09 (em breve).
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/perfil" StartIcon="@Icons.Material.Filled.Storefront">
                    Ir para meu perfil
                </MudButton>
            </MudPaper>

            <MudText Typo="Typo.h6" Class="mb-3">Vendas recentes</MudText>
            @if (!_vendas.Any())
            {
                <MudText Color="Color.Secondary">Nenhuma venda registrada.</MudText>
            }
            else
            {
                <MudTable Items="@_vendas.Take(10)" Hover="true" Dense="true" Elevation="1">
                    <HeaderContent>
                        <MudTh>Evento</MudTh>
                        <MudTh>Comprador</MudTh>
                        <MudTh>Valor</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="venda">
                        <MudTd>@venda.NomeEvento</MudTd>
                        <MudTd>@venda.NomeComprador</MudTd>
                        <MudTd>@venda.ValorFinalPago.ToString("C")</MudTd>
                        <MudTd>
                            @if (venda.Reembolsada)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Reembolsada</MudChip>
                            }
                            else if (venda.Pago)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Pago</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small">Pendente</MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
            <MudAlert Severity="Severity.Warning">Faça login como vendedor para acessar o painel.</MudAlert>
            <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Entrar</MudButton>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

<MudDialog @bind-Visible="_dialogCancelar" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Cancelar evento</MudText>
    </TitleContent>
    <DialogContent>
        @if (_carregandoStatus)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Consultando impacto do cancelamento…</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrEmpty(_erroStatus))
        {
            <MudAlert Severity="Severity.Error">@_erroStatus</MudAlert>
        }
        else if (_statusCancelamento is not null)
        {
            <MudText Class="mb-3">
                Deseja cancelar <b>@_statusCancelamento.Nome</b>?
            </MudText>
            <MudAlert Severity="@(_statusCancelamento.ReembolsoNecessario ? Severity.Warning : Severity.Info)" Dense="true" Class="mb-3">
                @_statusCancelamento.Mensagem
            </MudAlert>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Ingressos vendidos</MudText>
                    <MudText Typo="Typo.body2"><b>@_statusCancelamento.TotalIngressosVendidos</b></MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Reservas ativas</MudText>
                    <MudText Typo="Typo.body2"><b>@_statusCancelamento.TotalReservasAtivas</b></MudText>
                </MudItem>
                @if (_statusCancelamento.ReembolsoNecessario)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Valor total de reembolso</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Warning"><b>@_statusCancelamento.ValorTotalReembolso.ToString("C")</b></MudText>
                    </MudItem>
                }
                @if (_statusCancelamento.Gratuito)
                {
                    <MudItem xs="12">
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary">Evento gratuito</MudChip>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogCancelar = false">Voltar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   Disabled="_carregandoStatus || _statusCancelamento is null || !string.IsNullOrEmpty(_erroStatus)"
                   OnClick="ExecutarCancelamento">
            Confirmar cancelamento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<EventoViewModel>? _eventos;
    private List<ReservaVendedorDTO> _vendas = [];
    private bool _carregando = true;
    private bool _dialogCancelar;
    private bool _carregandoStatus;
    private Guid _eventoParaCancelar;
    private string? _erroStatus;
    private StatusCancelamentoViewModel? _statusCancelamento;
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    private class StatusCancelamentoViewModel
    {
        public Guid EventoId { get; set; }
        public string Nome { get; set; } = "";
        public bool Gratuito { get; set; }
        public int TotalIngressosVendidos { get; set; }
        public int TotalReservasAtivas { get; set; }
        public bool ReembolsoNecessario { get; set; }
        public decimal ValorTotalReembolso { get; set; }
        public string Mensagem { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregando = true;
        try
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token!);

            _eventos = await Http.GetFromJsonAsync<List<EventoViewModel>>("api/Evento/meus") ?? new();
            _vendas = await Http.GetFromJsonAsync<List<ReservaVendedorDTO>>("api/reserva/minhas-vendas") ?? new();
        }
        catch
        {
            _eventos = new();
            _vendas = new();
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task AbrirCancelamento(Guid id)
    {
        _eventoParaCancelar = id;
        _statusCancelamento = null;
        _erroStatus = null;
        _carregandoStatus = true;
        _dialogCancelar = true;

        try
        {
            var response = await Http.GetAsync($"api/Evento/{id}/status-cancelamento");

            if (response.IsSuccessStatusCode)
            {
                _statusCancelamento = await response.Content.ReadFromJsonAsync<StatusCancelamentoViewModel>();
            }
            else
            {
                var json = await response.Content.ReadAsStringAsync();
                var doc = System.Text.Json.JsonDocument.Parse(json);
                _erroStatus = doc.RootElement.TryGetProperty("message", out var msg)
                    ? msg.GetString()
                    : "Não foi possível consultar o status do cancelamento.";
            }
        }
        catch
        {
            _erroStatus = "Erro ao conectar com a API.";
        }
        finally
        {
            _carregandoStatus = false;
        }
    }

    private async Task ExecutarCancelamento()
    {
        _dialogCancelar = false;

        var response = await Http.DeleteAsync($"api/Evento/{_eventoParaCancelar}");

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Evento cancelado.", Severity.Success);
            await CarregarDados();
        }
        else
        {
            var json = await response.Content.ReadAsStringAsync();
            var doc = System.Text.Json.JsonDocument.Parse(json);
            var mensagem = doc.RootElement.TryGetProperty("message", out var msg) ? msg.GetString() : "Erro ao cancelar evento.";
            Snackbar.Add(mensagem, Severity.Error);
        }
    }
}
