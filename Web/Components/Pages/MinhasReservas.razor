@page "/reservas"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@using System.Net.Http.Headers
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-2">
    <div class="d-flex align-center mb-6">
        <img src="brand/logo-icon.png" alt="" class="plateia-logo-icon mr-3" aria-hidden="true" />
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800;">Minhas Reservas</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Seus ingressos digitais</MudText>
        </div>
    </div>

    @if (_carregando)
    {
        @for (var i = 0; i < 2; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" Class="mb-4" Style="border-radius: 12px;" />
        }
    }
    else if (!_reservas.Any())
    {
        <MudPaper Class="pa-10 text-center" Outlined="true" Style="border-radius: 16px;">
            <MudIcon Icon="@Icons.Material.Filled.EventSeat" Size="Size.Large" Color="Color.Secondary" Class="mb-3" Style="font-size: 64px;" />
            <MudText Typo="Typo.h6" Class="mb-2">Você ainda não possui reservas</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Explore eventos e escolha seu lugar no mapa interativo.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
                       Style="background: linear-gradient(135deg, var(--plateia-primary), var(--plateia-primary-light));">
                Explorar eventos
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid Class="plateia-stagger">
            @foreach (var reserva in _reservas)
            {
                var isVip = reserva.SetorIngresso?.Contains("VIP", StringComparison.OrdinalIgnoreCase) ?? false;
                <MudItem xs="12" md="6">
                    <div class="plateia-ticket h-100">
                        <div class="plateia-ticket__header">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <div>
                                    <MudText Typo="Typo.overline" Style="opacity: 0.75; letter-spacing: 0.1em;">INGRESSO</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">@reserva.NomeEvento</MudText>
                                    <MudText Typo="Typo.body2" Style="opacity: 0.85;">
                                        @reserva.DataEvento.ToString("dd/MM/yyyy 'às' HH:mm")
                                    </MudText>
                                </div>
                                @if (reserva.Reembolsada)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Style="background: rgba(255,255,255,0.2); color: #fff;">Reembolsada</MudChip>
                                }
                                else if (reserva.Pago || reserva.ValorFinalPago == 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Style="background: rgba(255,255,255,0.2); color: #fff;">
                                        @(reserva.ValorFinalPago == 0 ? "Gratuito" : "Pago")
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Style="background: rgba(255,255,255,0.2); color: #fff;">Pendente</MudChip>
                                }
                            </MudStack>
                        </div>

                        <div class="plateia-ticket__perforation"></div>

                        <div class="plateia-ticket__body">
                            <div class="plateia-ticket__seat-visual">
                                <div class="plateia-ticket__seat-icon">
                                    <MiniSeatIcon Label="@ExtrairNumeroAssento(reserva.PosicaoIngresso)" IsVip="@isVip" Size="52" />
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">ASSENTO</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">@reserva.PosicaoIngresso</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Setor @reserva.SetorIngresso</MudText>
                                </div>
                                <MudSpacer />
                                <div class="text-right">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">VALOR</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight: 700;">
                                        @reserva.ValorFinalPago.ToString("C")
                                    </MudText>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(reserva.CupomUtilizado))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Small" Class="mr-1" />
                                    Cupom: @reserva.CupomUtilizado
                                </MudText>
                            }

                            <div class="plateia-ticket__barcode"></div>

                            @if (!reserva.Reembolsada && reserva.DataEvento > DateTime.Now)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Class="mt-4"
                                           OnClick="() => SolicitarCancelamento(reserva.Id)">
                                    Cancelar reserva
                                </MudButton>
                            }
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<MudDialog @bind-Visible="_dialogCancelar" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Cancelar reserva</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Deseja cancelar esta reserva? Eventos pagos terão reembolso registrado.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _dialogCancelar = false">Voltar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ExecutarCancelamento">Confirmar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _carregando = true;
    private bool _dialogCancelar;
    private Guid _reservaParaCancelar;
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
    private List<ReservaDetalhadaDTO> _reservas = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token))
            {
                NavManager.NavigateTo("/login");
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var resultado = await Http.GetFromJsonAsync<List<ReservaDetalhadaDTO>>("api/reserva/minhas");
            _reservas = resultado ?? [];
        }
        catch
        {
            Snackbar.Add("Erro ao carregar suas reservas.", Severity.Error);
        }
        finally
        {
            _carregando = false;
        }
    }

    private static string ExtrairNumeroAssento(string? posicao)
    {
        if (string.IsNullOrWhiteSpace(posicao)) return "—";
        var digits = new string(posicao.Where(char.IsDigit).ToArray());
        return digits.Length > 0 ? digits : posicao.Length > 3 ? posicao[^2..] : posicao;
    }

    private void SolicitarCancelamento(Guid reservaId)
    {
        _reservaParaCancelar = reservaId;
        _dialogCancelar = true;
    }

    private async Task ExecutarCancelamento()
    {
        _dialogCancelar = false;

        try
        {
            var response = await Http.DeleteAsync($"api/reserva/{_reservaParaCancelar}");
            if (!response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                Snackbar.Add(ExtrairMensagem(json), Severity.Error);
                return;
            }

            Snackbar.Add("Reserva cancelada com sucesso.", Severity.Success);
            _reservas = await Http.GetFromJsonAsync<List<ReservaDetalhadaDTO>>("api/reserva/minhas") ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
    }

    private static string ExtrairMensagem(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("message", out var m))
                return m.GetString() ?? "Erro ao cancelar.";
        }
        catch { /* ignore */ }

        return "Erro ao cancelar.";
    }
}
