@page "/pagamento/{ReservaId:guid}"
@page "/pagamento/{EventoId}/{IngressoId}"
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Headers
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-2">
    <PurchaseStepper ActiveStep="2" />

    <MudText Typo="Typo.h4" Class="mb-6">Pagamento</MudText>

    @if (!string.IsNullOrEmpty(_totalFormatado))
    {
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Total: @_totalFormatado</MudText>
    }

    @if (!_pago)
    {
        <MudCard Elevation="2" Class="pa-6">
            <MudText Typo="Typo.h6" Class="mb-4">Selecione a forma de pagamento</MudText>

            <MudStack Spacing="2">
                @foreach (var metodo in _metodos)
                {
                    <MudPaper Outlined="true"
                              Class="@GetPaymentClass(metodo.Key)"
                              @onclick="() => _metodoPagamento = metodo.Key">
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@metodo.Icon" Color="Color.Primary" />
                            <MudText>@metodo.Label</MudText>
                        </div>
                    </MudPaper>
                }
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Class="mt-6"
                       Disabled="@(string.IsNullOrEmpty(_metodoPagamento) || _processando || ReservaId == Guid.Empty)"
                       OnClick="ConfirmarPagamento">
                @if (_processando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Processando...</span>
                }
                else
                {
                    <span>Confirmar pagamento</span>
                }
            </MudButton>
        </MudCard>
    }
    else
    {
        <MudCard Elevation="2" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 72px;" />
            <MudText Typo="Typo.h5" Class="mt-4 mb-2">Pagamento confirmado!</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
                Seus ingressos estão disponíveis em Minhas Reservas.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/reservas">
                Ver minhas reservas
            </MudButton>
        </MudCard>
    }
</MudContainer>

<style>
    .payment-option { transition: border-color 0.2s; cursor: pointer; }
    .payment-option--active { border-color: var(--plateia-primary) !important; border-width: 2px !important; }
</style>

@code {
    [Parameter] public Guid ReservaId { get; set; }
    [Parameter] public string? EventoId { get; set; }
    [Parameter] public string? IngressoId { get; set; }
    [SupplyParameterFromQuery(Name = "total")] public string? Total { get; set; }

    private string _metodoPagamento = "pix";
    private bool _processando;
    private bool _pago;
    private string _totalFormatado = "";

    private readonly (string Key, string Label, string Icon)[] _metodos =
    [
        ("pix", "PIX", Icons.Material.Filled.QrCode),
        ("credito", "Cartão de Crédito", Icons.Material.Filled.CreditCard),
        ("debito", "Cartão de Débito", Icons.Material.Filled.Payment),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!string.IsNullOrEmpty(EventoId) && !string.IsNullOrEmpty(IngressoId))
        {
            Snackbar.Add("Fluxo de pagamento atualizado. Use checkout → pagamento por reserva.", Severity.Warning);
            NavManager.NavigateTo($"/checkout/{EventoId}/{IngressoId}");
            return;
        }

        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
        {
            NavManager.NavigateTo("/login");
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        if (!string.IsNullOrEmpty(Total) && decimal.TryParse(Total, out var total))
            _totalFormatado = total.ToString("C");
        else
            _totalFormatado = "";

        StateHasChanged();
    }

    private async Task ConfirmarPagamento()
    {
        if (ReservaId == Guid.Empty) return;

        _processando = true;

        try
        {
            var payload = new { metodo = _metodoPagamento };
            var response = await Http.PostAsJsonAsync($"api/pagamento/checkout/{ReservaId}", payload);

            if (!response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                Snackbar.Add(ExtrairMensagem(json), Severity.Error);
                return;
            }

            _pago = true;
            Snackbar.Add("Pagamento realizado com sucesso!", Severity.Success);
            await Task.Delay(1500);
            NavManager.NavigateTo("/reservas");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processando = false;
        }
    }

    private static string ExtrairMensagem(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("message", out var m))
                return m.GetString() ?? "Erro no pagamento.";
        }
        catch { /* ignore */ }

        return "Erro no pagamento.";
    }

    private string GetPaymentClass(string key) =>
        $"pa-4 cursor-pointer payment-option {(_metodoPagamento == key ? "payment-option--active" : "")}";
}
