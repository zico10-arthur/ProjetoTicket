@page "/"
@inject HttpClient Http
@using Web.Mock

<MudStack Spacing="6">

    <!-- ══════════════════════════════════════
         HERO SECTION
    ══════════════════════════════════════════ -->
    <MudPaper Elevation="0" Class="plateia-hero pa-8 pa-sm-10">
        <div class="plateia-hero__mesh"></div>
        <div class="plateia-hero__orb plateia-hero__orb--1"></div>
        <div class="plateia-hero__orb plateia-hero__orb--2"></div>

        <MudGrid Class="plateia-hero__content align-center" Spacing="4">

            <!-- Coluna Esquerda: Textos e CTAs -->
            <MudItem xs="12" md="7">

                <!-- Estatísticas (glassmorphism) -->
                <MudStack Row="true" Spacing="2" Class="mb-6 flex-wrap">
                    <div class="plateia-hero__stat">
                        <div class="plateia-hero__stat-value">
                            @(_totalEventosAtivos?.ToString() ?? "—")
                        </div>
                        <div class="plateia-hero__stat-label">Eventos Ativos</div>
                    </div>
                    <div class="plateia-hero__stat">
                        <div class="plateia-hero__stat-value">4</div>
                        <div class="plateia-hero__stat-label">Assentos por Reserva</div>
                    </div>
                    <div class="plateia-hero__stat">
                        <div class="plateia-hero__stat-value">100%</div>
                        <div class="plateia-hero__stat-label">Online</div>
                    </div>
                </MudStack>

                <!-- H1 Headline -->
                <MudText Typo="Typo.h3"
                         Class="mb-4"
                         Style="color: #fff; font-weight: 800; line-height: 1.15;">
                    Sua plateia. Seu lugar.<br />Sua experiência.
                </MudText>

                <!-- Sub-headline -->
                <MudText Typo="Typo.body1"
                         Class="mb-7"
                         Style="color: rgba(255,255,255,0.88); max-width: 480px; font-size: 1.05rem; line-height: 1.65;">
                    Teatros, palestras e workshops com mapa de assentos interativo,
                    cupons e checkout em poucos cliques.
                </MudText>

                <!-- CTAs -->
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Filled"
                               Style="background: #fff; color: var(--plateia-primary); font-weight: 700; box-shadow: 0 4px 16px rgba(0,0,0,0.18);"
                               Href="#eventos"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Event">
                        Explorar eventos
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Class="plateia-cta-accent"
                               Href="/cadastro-vendedor"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Storefront">
                        Quero vender
                    </MudButton>
                </MudStack>

            </MudItem>

            <!-- Coluna Direita: Mockup do celular (CSS) -->
            <MudItem xs="12" md="5" Class="d-flex align-center justify-center plateia-hero__visual">
                <HeroPhoneMockup />
            </MudItem>

        </MudGrid>
    </MudPaper>

    <!-- ══════════════════════════════════════
         SEÇÃO DE RECURSOS (Feature Cards)
    ══════════════════════════════════════════ -->
    <MudGrid Spacing="3">

        <!-- Card 1: Assentos em tempo real -->
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1" Class="plateia-feature-card h-100">
                <MudCardContent>
                    <div class="plateia-feature-icon plateia-feature-icon--purple mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.EventSeat" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <b>Assentos em tempo real</b>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #0F766E; line-height: 1.6;">
                        Escolha VIP ou Geral no mapa interativo — veja disponibilidade ao vivo.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Card 2: Compre para o grupo -->
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1" Class="plateia-feature-card h-100">
                <MudCardContent>
                    <div class="plateia-feature-icon plateia-feature-icon--teal mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <b>Compre para o grupo</b>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #0F766E; line-height: 1.6;">
                        Até 4 participantes por reserva — informe o CPF de cada um no checkout.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Card 3: Cupons e eventos grátis -->
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1" Class="plateia-feature-card h-100">
                <MudCardContent>
                    <div class="plateia-feature-icon plateia-feature-icon--gold mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.LocalOffer" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <b>Cupons e eventos grátis</b>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #A8863F; line-height: 1.6;">
                        Descontos exclusivos e reservas gratuitas sem passar pelo pagamento.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

    <!-- ══════════════════════════════════════
         SEÇÃO DE EVENTOS
    ══════════════════════════════════════════ -->
    <div id="eventos">
        <div class="plateia-section-header">
            <MudText Class="plateia-section-title">Eventos disponíveis</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(eventos?.Count(e => !e.Cancelado) ?? 0) evento(s) para você
            </MudText>
        </div>
    </div>

    <MudGrid Spacing="4" Class="plateia-stagger">
        @if (eventos is null)
        {
            @for (var i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="320px" Style="border-radius: 12px;" />
                </MudItem>
            }
        }
        else if (!eventos.Any(e => !e.Cancelado))
        {
            <MudItem xs="12">
                <MudPaper Class="pa-10 text-center" Outlined="true" Style="border-radius: 16px;">
                    <img src="brand/logo-icon.png" alt="" style="width: 64px; opacity: 0.6; margin-bottom: 16px;" />
                    <MudText Typo="Typo.h6" Class="mb-2">Nenhum evento disponível no momento</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Volte em breve ou cadastre-se como vendedor para publicar seu evento.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Class="plateia-cta-accent" Href="/cadastro-vendedor">
                        Quero Vender
                    </MudButton>
                </MudPaper>
            </MudItem>
        }
        else
        {
            @foreach (var evento in eventos.Where(e => !e.Cancelado))
            {
                <MudItem xs="12" sm="6" lg="4">
                    <CartaoEvento Evento="@evento" ModoDemo="@_modoDemo" />
                </MudItem>
            }
        }
    </MudGrid>

</MudStack>

@code {
    private List<EventoViewModel>? eventos;
    private bool _modoDemo;
    private int? _totalEventosAtivos => eventos?.Count(e => !e.Cancelado);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eventos = await Http.GetFromJsonAsync<List<EventoViewModel>>("api/Evento");
            if (eventos is null || eventos.Count == 0)
                CarregarMock();
        }
        catch
        {
            CarregarMock();
        }
    }

    private void CarregarMock()
    {
        _modoDemo = true;
        eventos = PlateiaMockData.GetEventos();
    }
}
