@page "/checkout/{EventoId}"
@page "/checkout/{EventoId}/{IngressoId}"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject PurchaseStateService PurchaseState
@using System.Net.Http.Headers
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-2">
    <PurchaseStepper ActiveStep="1" />

    <MudText Typo="Typo.h4" Class="mb-6">Checkout</MudText>

    @if (_carregando)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="320px" />
    }
    else if (_evento == null)
    {
        <MudAlert Severity="Severity.Error">Erro ao carregar dados da reserva.</MudAlert>
    }
    else if (!_itens.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Nenhum assento selecionado. Volte ao mapa para escolher seus lugares.
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/comprar/{EventoId}/ingressos")">
            Escolher assentos
        </MudButton>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudCard Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h6" Color="Color.Primary">@_evento.Nome</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        @_evento.DataEvento.ToString("dd/MM/yyyy HH:mm")
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Class="mb-3"><b>Participantes (CPF)</b></MudText>
                    @for (var i = 0; i < _itens.Count; i++)
                    {
                        var index = i;
                        <MudTextField @bind-Value="_cpfs[index]"
                                      Label="@($"CPF — {_itens[index].DisplayLabel} ({_itens[index].Setor})")"
                                      Variant="Variant.Outlined"
                                      Class="mb-3"
                                      InputMode="InputMode.numeric"
                                      MaxLength="14" />
                    }
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudCard Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-4">Resumo</MudText>

                    @foreach (var item in _itens)
                    {
                        <div class="d-flex justify-space-between mb-2">
                            <MudText Typo="Typo.body2">@item.DisplayLabel · @item.Setor</MudText>
                            <MudText Typo="Typo.body2">@item.Preco.ToString("C")</MudText>
                        </div>
                    }

                    @if (!_evento.IsGratuito)
                    {
                        <MudSelect T="CupomOpcao?"
                                   Label="Cupom de desconto"
                                   Value="_cupomSelecionado"
                                   ValueChanged="OnCupomChanged"
                                   Variant="Variant.Outlined"
                                   Class="my-4"
                                   Clearable="true">
                            @foreach (var c in _cupons)
                            {
                                <MudSelectItem Value="@(new CupomOpcao(c.Codigo, c.PorcentagemDesconto, c.ValorMinimo))">
                                    @c.Codigo (@c.PorcentagemDesconto% OFF)
                                </MudSelectItem>
                            }
                        </MudSelect>

                        @if (_valorDesconto > 0)
                        {
                            <div class="d-flex justify-space-between mb-2" style="color: #059669;">
                                <MudText>Desconto:</MudText>
                                <MudText>- @_valorDesconto.ToString("C")</MudText>
                            </div>
                        }
                    }

                    <MudDivider Class="my-3" />

                    <div class="d-flex justify-space-between mb-6">
                        <MudText Typo="Typo.h6"><b>Total</b></MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary"><b>@_valorFinal.ToString("C")</b></MudText>
                    </div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="@_processando"
                               OnClick="ConfirmarReserva">
                        @if (_processando)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        @(_evento.IsGratuito ? "Confirmar reserva" : "Ir para pagamento")
                    </MudButton>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public string EventoId { get; set; } = "";
    [Parameter] public string? IngressoId { get; set; }

    private bool _carregando = true;
    private bool _processando;
    private EventoViewModel? _evento;
    private List<SelectedSeatState> _itens = [];
    private List<string> _cpfs = [];
    private List<CupomOpcao> _cupons = [];
    private CupomOpcao? _cupomSelecionado;
    private decimal _valorDesconto;
    private decimal _valorFinal;

    private sealed record CupomOpcao(string Codigo, int PorcentagemDesconto, decimal ValorMinimo);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
        {
            NavManager.NavigateTo($"/login?returnUrl=/checkout/{EventoId}");
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        try
        {
            _evento = await Http.GetFromJsonAsync<EventoViewModel>($"api/Evento/{EventoId}");

            if (Guid.TryParse(EventoId, out var eventoGuid) && PurchaseState.MatchesEvent(eventoGuid))
            {
                _itens = PurchaseState.SelectedSeats;
            }
            else if (!string.IsNullOrEmpty(IngressoId) && Guid.TryParse(IngressoId, out var ingressoGuid))
            {
                var ingresso = await Http.GetFromJsonAsync<IngressoResponseDTO>($"api/Ingresso/{IngressoId}");
                if (ingresso != null)
                {
                    _itens =
                    [
                        new SelectedSeatState(ingressoGuid, ingresso.Posicao, ingresso.Setor, ingresso.Preco, ingresso.Posicao)
                    ];
                }
            }

            _cpfs = Enumerable.Repeat("", _itens.Count).ToList();
            _valorFinal = _itens.Sum(i => i.Preco);

            if (_evento is { IsGratuito: false })
            {
                var cupons = await Http.GetFromJsonAsync<List<CupomOpcao>>("api/Cupom/ListarCuponsValidos");
                _cupons = cupons ?? [];
            }
        }
        catch
        {
            Snackbar.Add("Erro ao carregar checkout.", Severity.Error);
        }
        finally
        {
            _carregando = false;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        RecalcularTotal();
    }

    private void RecalcularTotal()
    {
        var subtotal = _itens.Sum(i => i.Preco);
        _valorDesconto = 0;

        if (_cupomSelecionado != null && subtotal >= _cupomSelecionado.ValorMinimo)
            _valorDesconto = subtotal * (_cupomSelecionado.PorcentagemDesconto / 100m);

        _valorFinal = Math.Max(0, subtotal - _valorDesconto);
    }

    private void OnCupomChanged(CupomOpcao? cupom)
    {
        _cupomSelecionado = cupom;
        RecalcularTotal();
    }

    private async Task ConfirmarReserva()
    {
        if (_evento == null || !_itens.Any()) return;

        for (var i = 0; i < _cpfs.Count; i++)
        {
            var cpf = NormalizarCpf(_cpfs[i]);
            if (cpf.Length != 11)
            {
                Snackbar.Add($"CPF inválido para o assento {_itens[i].DisplayLabel}.", Severity.Warning);
                return;
            }
            _cpfs[i] = cpf;
        }

        _processando = true;

        try
        {
            var dto = new ReservarDTO
            {
                EventoId = Guid.Parse(EventoId),
                CupomCodigo = _evento.IsGratuito ? null : _cupomSelecionado?.Codigo,
                Itens = _itens.Zip(_cpfs, (item, cpf) => new ItemReservaRequestDTO
                {
                    IngressoId = item.IngressoId,
                    CpfParticipante = cpf
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/reserva/criar", dto);
            if (!response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var msg = ExtrairMensagem(json);
                Snackbar.Add(msg, Severity.Error);
                return;
            }

            var body = await response.Content.ReadAsStringAsync();
            var doc = JsonDocument.Parse(body);
            var reservaId = doc.RootElement.GetProperty("reservaId").GetGuid();

            PurchaseState.Clear();

            if (_evento.IsGratuito)
            {
                Snackbar.Add("Reserva confirmada!", Severity.Success);
                NavManager.NavigateTo("/reservas");
            }
            else
            {
                NavManager.NavigateTo($"/pagamento/{reservaId}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processando = false;
        }
    }

    private static string NormalizarCpf(string cpf) =>
        new string(cpf.Where(char.IsDigit).ToArray());

    private static string ExtrairMensagem(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("message", out var m))
                return m.GetString() ?? "Erro ao criar reserva.";
        }
        catch { /* ignore */ }

        return "Erro ao criar reserva.";
    }
}
