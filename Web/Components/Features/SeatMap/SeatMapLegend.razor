@namespace Web.Components.Features.SeatMap

<div class="t360-legend">
    <div class="t360-legend__item">
        <span class="t360-legend__swatch t360-legend__swatch--open"></span>
        <span>Disponível</span>
    </div>
    <div class="t360-legend__item">
        <span class="t360-legend__swatch t360-legend__swatch--vip"></span>
        <span>VIP</span>
    </div>
    <div class="t360-legend__item">
        <span class="t360-legend__swatch t360-legend__swatch--picked"></span>
        <span>Selecionado</span>
    </div>
    <div class="t360-legend__item">
        <span class="t360-legend__swatch t360-legend__swatch--sold"></span>
        <span>Vendido</span>
    </div>

    @if (ShowSectorFilter)
    {
        <div class="t360-legend__filters">
            @foreach (var option in _options)
            {
                <button type="button"
                        class="t360-legend__filter @(Filter == option ? "t360-legend__filter--active" : "")"
                        @onclick="() => SetFilter(option)">
                    @option
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public bool ShowSectorFilter { get; set; } = true;
    [Parameter] public string Filter { get; set; } = "Todos";
    [Parameter] public EventCallback<string> FilterChanged { get; set; }

    private readonly string[] _options = ["Todos", "VIP", "Geral"];

    private async Task SetFilter(string value) => await FilterChanged.InvokeAsync(value);
}
