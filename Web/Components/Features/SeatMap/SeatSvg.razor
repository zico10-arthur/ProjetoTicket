@namespace Web.Components.Features.SeatMap

<g class="t360-seat @StateClass @(IsOccupied ? "t360-seat--disabled" : "")"
   transform="translate(@Fx, @Fy)"
   @onclick="HandleClick"
   @onclick:stopPropagation="true"
   role="button"
   aria-label="@AriaLabel">
    <title>@TooltipText</title>
    <rect class="t360-seat__hit" x="0" y="0" width="@S" height="@S" rx="5" />
    <rect class="t360-seat__shape" x="1" y="1" width="@Inner" height="@Inner" rx="4" />
    @if (IsSelected)
    {
        <rect class="t360-seat__ring" x="0" y="0" width="@S" height="@S" rx="5" fill="none" />
    }
    <svg:text x="@Half" y="@TextY" text-anchor="middle" class="t360-seat__num">@Seat.GlobalSeatNumber</svg:text>
</g>

@code {
    [Parameter, EditorRequired] public SeatModel Seat { get; set; } = null!;
    [Parameter] public double X { get; set; }
    [Parameter] public double Y { get; set; }
    [Parameter] public EventCallback<int> OnToggle { get; set; }

    private const double S = SeatLayoutEngine.SeatSize;
    private double Inner => S - 2;
    private double Half => S / 2;
    private double TextY => S - 6;

    private string Fx => X.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    private string Fy => Y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private bool IsOccupied => Seat.Status == SeatStatus.Occupied;
    private bool IsSelected => Seat.Status == SeatStatus.Selected;

    private string StateClass => IsOccupied
        ? "t360-seat--sold"
        : IsSelected
            ? "t360-seat--picked"
            : Seat.IsVip
                ? "t360-seat--vip"
                : "t360-seat--open";

    private string TooltipText => IsOccupied
        ? $"{Seat.DisplayLabel} · {Seat.Setor} — Vendido"
        : $"{Seat.DisplayLabel} · {Seat.Setor} · {Seat.Price:C}";

    private string AriaLabel => TooltipText;

    private async Task HandleClick()
    {
        if (IsOccupied) return;
        await OnToggle.InvokeAsync(Seat.Id);
    }
}
