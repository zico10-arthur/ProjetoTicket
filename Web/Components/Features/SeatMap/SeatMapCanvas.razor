@namespace Web.Components.Features.SeatMap
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="t360-map" id="@_viewportId">
    <div class="t360-map__surface">
        <div class="t360-map__transform">
            <svg class="t360-map__svg"
                 viewBox="@ViewBox"
                 preserveAspectRatio="xMidYMid meet"
                 xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="@_gradStage" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#374151" />
                        <stop offset="100%" stop-color="#111827" />
                    </linearGradient>
                    <filter id="@_shadowStage" x="-20%" y="-20%" width="140%" height="140%">
                        <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#000" flood-opacity="0.25" />
                    </filter>
                </defs>

                <rect class="t360-map__floor" x="0" y="0" width="@_layout.Width" height="@_layout.Height" />

                <path class="t360-map__stage-fill"
                      d="@SeatLayoutEngine.StagePath(_layout.Stage)"
                      fill="@($"url(#{_gradStage})")"
                      filter="@($"url(#{_shadowStage})")" />
                <path class="t360-map__stage-edge"
                      d="@SeatLayoutEngine.StageFrontLine(_layout.Stage)"
                      fill="none" />

                @foreach (var label in _layout.Labels)
                {
                    <svg:text x="@Fmt(label.X)"
                              y="@Fmt(label.Y)"
                              text-anchor="@label.Anchor"
                              class="@label.CssClass">@label.Text</svg:text>
                }

                @if (_aisle is not null)
                {
                    <rect class="t360-map__aisle"
                          x="@Fmt(_aisle.Value.X)"
                          y="@Fmt(_aisle.Value.Y)"
                          width="@Fmt(_aisle.Value.W)"
                          height="@Fmt(_aisle.Value.H)"
                          rx="3" />
                }

                @foreach (var item in _layout.Seats)
                {
                    <SeatSvg Seat="item.Seat" X="item.X" Y="item.Y" OnToggle="OnToggle" />
                }
            </svg>
        </div>
    </div>

    <div class="t360-map__toolbar">
        <button type="button" class="t360-map__tool" @onclick="ZoomOutAsync" aria-label="Diminuir zoom">
            <span>−</span>
        </button>
        <button type="button" class="t360-map__tool" @onclick="ResetViewAsync" aria-label="Centralizar">
            <span>◎</span>
        </button>
        <button type="button" class="t360-map__tool" @onclick="ZoomInAsync" aria-label="Aumentar zoom">
            <span>+</span>
        </button>
    </div>
</div>

@code {
    [Parameter] public List<SeatModel> Seats { get; set; } = [];
    [Parameter] public string SectorFilter { get; set; } = "Todos";
    [Parameter] public EventCallback<int> OnToggle { get; set; }

    private readonly string _viewportId = $"t360-{Guid.NewGuid():N}";
    private readonly string _gradStage = $"gs-{Guid.NewGuid():N}"[..10];
    private readonly string _shadowStage = $"ss-{Guid.NewGuid():N}"[..10];

    private SeatLayoutEngine.Layout _layout = SeatLayoutEngine.Build([], "Todos");
    private (double X, double Y, double W, double H)? _aisle;
    private string ViewBox => $"0 0 {_layout.Width} {_layout.Height}";
    private bool _jsReady;

    protected override void OnParametersSet()
    {
        _layout = SeatLayoutEngine.Build(Seats, SectorFilter);
        _aisle = BuildAisle();
    }

    private (double X, double Y, double W, double H)? BuildAisle()
    {
        if (_layout.Seats.Count == 0) return null;

        var left = _layout.Seats.Where(s => s.Seat.Block == SeatBlock.Left).ToList();
        var right = _layout.Seats.Where(s => s.Seat.Block == SeatBlock.Right).ToList();
        if (left.Count == 0 || right.Count == 0) return null;

        var leftMax = left.Max(s => s.X + SeatLayoutEngine.SeatSize);
        var rightMin = right.Min(s => s.X);
        var h = Seats.Select(s => s.RowLabel).Distinct().Count()
              * (SeatLayoutEngine.SeatSize + SeatLayoutEngine.RowGap)
              - SeatLayoutEngine.RowGap
              + SeatLayoutEngine.ColHeaderHeight;

        return (leftMax + 3, _layout.GridTop + SeatLayoutEngine.ColHeaderHeight - 2, rightMin - leftMax - 6, h + 4);
    }

    private static string Fmt(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsReady) return;
        await JS.InvokeVoidAsync("plateiaSeatMap.init", _viewportId);
        _jsReady = true;
    }

    public Task ZoomInAsync() => JS.InvokeVoidAsync("plateiaSeatMap.zoomIn", _viewportId).AsTask();
    public Task ZoomOutAsync() => JS.InvokeVoidAsync("plateiaSeatMap.zoomOut", _viewportId).AsTask();
    public Task ResetViewAsync() => JS.InvokeVoidAsync("plateiaSeatMap.reset", _viewportId).AsTask();

    public async ValueTask DisposeAsync()
    {
        if (_jsReady)
            await JS.InvokeVoidAsync("plateiaSeatMap.dispose", _viewportId);
    }
}
