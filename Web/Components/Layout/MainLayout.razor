@inherits LayoutComponentBase
@using Web.Theme
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="@PlateiaTheme.Theme" IsDarkMode="false" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Class="plateia-navbar">
        <img src="brand/logo.png" alt="Plateia" class="plateia-logo ml-3" @onclick='() => NavManager.NavigateTo("/")' />

        <MudSpacer />

        <AuthorizeView>
            <NotAuthorized>
                <div class="d-flex align-center gap-2 mr-2">
                    <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">
                        Entrar
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/cadastro">
                        Cadastrar
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Class="plateia-cta-accent" Href="/cadastro-vendedor">
                        Quero Vender
                    </MudButton>
                </div>
            </NotAuthorized>

            <Authorized>
                <AuthorizeView Roles="Comprador" Context="compradorCtx">
                    <div class="d-flex gap-2 mr-4">
                        <MudButton Color="Color.Inherit" Href="/">Eventos</MudButton>
                        <MudButton Color="Color.Inherit" Href="/cupons">Cupons</MudButton>
                    </div>
                    <MudSpacer />
                    <MudMenu Label="@compradorCtx.User.Identity?.Name" Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                        <MudMenuItem Href="/perfil">Meu Perfil</MudMenuItem>
                        <MudMenuItem Href="/reservas">Minhas Reservas</MudMenuItem>
                        <MudMenuItem OnClick="Deslogar">Sair</MudMenuItem>
                    </MudMenu>
                </AuthorizeView>

                <AuthorizeView Roles="Vendedor" Context="vendedorCtx">
                    <div class="d-flex gap-2 mr-4">
                        <MudButton Color="Color.Inherit" Href="/">Eventos</MudButton>
                        <MudButton Color="Color.Inherit" Href="/eventos/meus">Painel</MudButton>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Href="/eventos/criar">Criar Evento</MudButton>
                    </div>
                    <MudSpacer />
                    <MudMenu Label="@vendedorCtx.User.Identity?.Name" Icon="@Icons.Material.Filled.Storefront" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                        <MudMenuItem Href="/perfil">Meu Perfil</MudMenuItem>
                        <MudMenuItem Href="/eventos/meus">Meus Eventos</MudMenuItem>
                        <MudMenuItem Href="/reservas">Minhas Reservas</MudMenuItem>
                        <MudMenuItem OnClick="Deslogar">Sair</MudMenuItem>
                    </MudMenu>
                </AuthorizeView>

                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <div class="d-flex gap-2 mr-4 flex-wrap">
                        <MudButton Color="Color.Inherit" Href="/admin/eventos">Eventos</MudButton>
                        <MudMenu Label="Cupons" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter">
                            <MudMenuItem Href="/admin/cupons">Mostrar Cupons</MudMenuItem>
                            <MudMenuItem Href="/admin/cupons/criar">Criar Cupons</MudMenuItem>
                        </MudMenu>
                        <MudMenu Label="Usuários" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter">
                            <MudMenuItem Href="/admin/usuarios">Ver Usuários</MudMenuItem>
                        </MudMenu>
                        <MudButton Color="Color.Inherit" Href="/admin/reservas">Reservas</MudButton>
                        <MudButton Color="Color.Inherit" Href="/admin/pagamentos">Pagamentos</MudButton>
                    </div>
                    <MudSpacer />
                    <MudMenu Label="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                        <MudMenuItem Href="/perfil">Meu Perfil</MudMenuItem>
                        <MudMenuItem Href="/reservas">Minhas Reservas</MudMenuItem>
                        <MudMenuItem OnClick="Deslogar">Sair</MudMenuItem>
                    </MudMenu>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-4 plateia-page-enter">
            @Body
        </MudContainer>
        <PlateiaFooter />
    </MudMainContent>
</MudLayout>

@code {
    [Inject] NavigationManager NavManager { get; set; } = null!;

    private async Task Deslogar()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        ((CustomAuthStateProvider)AuthStateProvider).MarcarUsuarioComoDeslogado();
        NavManager.NavigateTo("/login");
    }
}
