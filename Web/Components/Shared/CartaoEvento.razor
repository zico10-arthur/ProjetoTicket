@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<MudCard Elevation="2" Class="event-card h-100" Style="@($"border-top: 4px solid {CapaCor};")">
    <div class="event-card-cover pa-4" style="@($"background: linear-gradient(135deg, {CapaCor}22, {CapaCor}44);")">
        <MudStack Row="true" Spacing="1" Class="mb-2">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@Evento.TipoLabel</MudChip>
            @if (Evento.IsGratuito)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">Gratuito</MudChip>
            }
        </MudStack>
        <MudText Typo="Typo.h6" Class="event-card-title"><b>@Evento.Nome</b></MudText>
    </div>

    <MudCardContent>
        @if (!string.IsNullOrWhiteSpace(Evento.Local))
        {
            <div class="d-flex align-center mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Evento.Local</MudText>
            </div>
        }

        <div class="d-flex align-center mb-2">
            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.body2">@Evento.DataEvento.ToString("dd/MM/yyyy HH:mm")</MudText>
        </div>

        <div class="d-flex align-center justify-space-between">
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Evento.CapacidadeTotal lugares</MudText>
            @if (Evento.IsGratuito)
            {
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary"><b>Grátis</b></MudText>
            }
            else
            {
                <MudText Typo="Typo.subtitle1" Color="Color.Primary"><b>@Evento.PrecoPadrao.ToString("C")</b></MudText>
            }
        </div>
    </MudCardContent>

    <MudCardActions Class="pa-4 pt-0">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="IrParaCompra"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            @(Evento.IsGratuito ? "Reservar vaga" : "Comprar ingresso")
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public EventoViewModel Evento { get; set; } = null!;

    [Parameter]
    public bool ModoDemo { get; set; }

    private string CapaCor => Evento.Tipo == 1 ? "#4F46E5" : "#7C3AED";

    private async Task IrParaCompra()
    {
        if (ModoDemo)
        {
            NavManager.NavigateTo("/demo/assentos");
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.Identity?.IsAuthenticated ?? true)
            NavManager.NavigateTo($"/login?returnUrl=/comprar/{Evento.Id}/ingressos");
        else
            NavManager.NavigateTo($"/comprar/{Evento.Id}/ingressos");
    }
}
