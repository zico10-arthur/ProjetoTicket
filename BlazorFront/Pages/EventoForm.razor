@page "/eventos/novo"
@page "/eventos/editar/{Id:guid}"
@inject BlazorFront.Services.EventoService EventoService
@inject NavigationManager Nav

<h3>@(Id == null ? "Novo Evento" : "Editar Evento")</h3>

<EditForm Model="modelo" OnValidSubmit="Salvar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Nome</label>
        <InputText class="form-control" @bind-Value="modelo.Nome" />
    </div>
    <div class="mb-3">
        <label class="form-label">Data do Evento</label>
        <InputDate class="form-control" @bind-Value="modelo.DataEvento" />
    </div>
    <div class="mb-3">
        <label class="form-label">Capacidade Total</label>
        <InputNumber class="form-control" @bind-Value="modelo.CapacidadeTotal" />
    </div>
    <div class="mb-3">
        <label class="form-label">Preço Padrão (R$)</label>
        <InputNumber class="form-control" @bind-Value="modelo.PrecoPadrao" />
    </div>

    @if (erro != null)
    {
        <div class="alert alert-danger mt-3">@erro</div>
    }

    <button type="submit" class="btn btn-success me-2">Salvar</button>
    <button type="button" class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/eventos")'>Cancelar</button>
</EditForm>

@code {
    [Parameter] public Guid? Id { get; set; }

    private BlazorFront.Models.EventoModel modelo = new();
    private string? erro;

    protected override async Task OnParametersSetAsync()
    {
        if (Id != null)
        {
            try
            {
                modelo = await EventoService.GetByIdAsync(Id.Value) ?? new();
            }
            catch (Exception ex)
            {
                erro = $"Erro ao carregar evento: {ex.Message}";
            }
        }
    }

    private async Task Salvar()
    {
        try
        {
            if (Id == null)
                await EventoService.CreateAsync(modelo);
            else
                await EventoService.UpdateAsync(Id.Value, modelo);

            Nav.NavigateTo("/eventos");
        }
        catch (Exception ex)
        {
            erro = $"Erro ao salvar: {ex.Message}";
        }
    }
}
