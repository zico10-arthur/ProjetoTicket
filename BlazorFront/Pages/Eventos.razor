@page "/eventos"
@inject BlazorFront.Services.EventoService EventoService
@inject NavigationManager Nav

<h3 class="text-royal fw-bold mb-3">Eventos</h3>

<button class="btn btn-royal mb-3" @onclick='() => Nav.NavigateTo("/eventos/novo")'>+ Novo Evento</button>

@if (loading)
{
    <p class="text-muted">Carregando...</p>
}
else if (erro != null)
{
    <div class="alert alert-danger">@erro</div>
}
else
{
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-royal">
                <tr>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Capacidade</th>
                    <th>Preço</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evento in eventos)
                {
                    <tr>
                        <td>@evento.Nome</td>
                        <td>@evento.DataEvento.ToString("dd/MM/yyyy")</td>
                        <td>@evento.CapacidadeTotal</td>
                        <td>R$ @evento.PrecoPadrao.ToString("F2")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-royal me-1" @onclick='() => Nav.NavigateTo($"/eventos/editar/{evento.Id}")'>Editar</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Deletar(evento.Id)">Deletar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<BlazorFront.Models.EventoModel> eventos = [];
    private bool loading = true;
    private string? erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eventos = await EventoService.GetAllAsync();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar eventos: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Deletar(Guid id)
    {
        try
        {
            await EventoService.DeleteAsync(id);
            eventos = await EventoService.GetAllAsync();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao deletar: {ex.Message}";
        }
    }
}
