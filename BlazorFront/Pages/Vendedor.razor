@page "/vendedor"
@layout LoggedLayout
@inject NavigationManager Nav

<PageTitle>Sold Out Tickets - Vendedor</PageTitle>

<div class="container pb-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-royal fw-bold mb-0">Meus Eventos</h3>
        <button class="btn btn-royal" @onclick="() => mostrarFormulario = true">+ Novo Evento</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card shadow-sm p-4 mb-4" style="max-width: 540px;">
            <h5 class="text-royal fw-bold mb-3">Cadastrar Evento</h5>
            <div class="mb-3">
                <label class="form-label fw-semibold">Nome</label>
                <input class="form-control" @bind="novoEvento.Nome" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Data do Evento</label>
                <input type="date" class="form-control" @bind="novoEvento.DataEvento" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Capacidade Total</label>
                <input type="number" class="form-control" @bind="novoEvento.CapacidadeTotal" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Preço Padrão (R$)</label>
                <input type="number" class="form-control" @bind="novoEvento.PrecoPadrao" />
            </div>
            @if (mensagem != null)
            {
                <div class="alert alert-success">@mensagem</div>
            }
            <div class="d-flex gap-2">
                <!-- TODO: integrar com EventoService.CreateAsync -->
                <button class="btn btn-royal" @onclick="CadastrarEvento">Salvar</button>
                <button class="btn btn-outline-secondary" @onclick="() => { mostrarFormulario = false; mensagem = null; }">Cancelar</button>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-royal">
                <tr>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Capacidade</th>
                    <th>Preço</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evento in eventos)
                {
                    <tr>
                        <td>@evento.Nome</td>
                        <td>@evento.DataEvento.ToString("dd/MM/yyyy")</td>
                        <td>@evento.CapacidadeTotal</td>
                        <td>R$ @evento.PrecoPadrao.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool mostrarFormulario = false;
    private string? mensagem;
    private EventoModel novoEvento = new();

    // TODO: substituir por chamada real ao EventoService filtrada pelo vendedor logado
    private List<EventoModel> eventos = [
        new() { Id = Guid.NewGuid(), Nome = "Show de Rock", CapacidadeTotal = 500, DataEvento = DateTime.Now.AddDays(10), PrecoPadrao = 120.00m },
        new() { Id = Guid.NewGuid(), Nome = "Festival de Jazz", CapacidadeTotal = 300, DataEvento = DateTime.Now.AddDays(20), PrecoPadrao = 80.00m },
    ];

    private void CadastrarEvento()
    {
        // TODO: integrar com EventoService.CreateAsync
        eventos.Add(new EventoModel
        {
            Id = Guid.NewGuid(),
            Nome = novoEvento.Nome,
            CapacidadeTotal = novoEvento.CapacidadeTotal,
            DataEvento = novoEvento.DataEvento,
            PrecoPadrao = novoEvento.PrecoPadrao
        });
        mensagem = $"Evento \"{novoEvento.Nome}\" cadastrado com sucesso!";
        novoEvento = new();
    }
}
