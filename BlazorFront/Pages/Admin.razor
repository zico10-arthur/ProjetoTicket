@page "/admin"
@layout LoggedLayout

<PageTitle>Sold Out Tickets - Admin</PageTitle>

<div class="container pb-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-royal fw-bold mb-0">Gerenciar Usuários</h3>
        <button class="btn btn-royal" @onclick="() => mostrarFormulario = true">+ Novo Usuário</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card shadow-sm p-4 mb-4" style="max-width: 480px;">
            <h5 class="text-royal fw-bold mb-3">Cadastrar Usuário</h5>
            <div class="mb-3">
                <label class="form-label fw-semibold">Nome</label>
                <input class="form-control" @bind="novoUsuario.Nome" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">E-mail</label>
                <input type="email" class="form-control" @bind="novoUsuario.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Perfil</label>
                <select class="form-select" @bind="novoUsuario.Perfil">
                    <option value="">Selecione...</option>
                    <option value="Vendedor">Vendedor</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            @if (mensagem != null)
            {
                <div class="alert alert-success">@mensagem</div>
            }
            <div class="d-flex gap-2">
                <!-- TODO: integrar com endpoint de cadastro de usuários -->
                <button class="btn btn-royal" @onclick="CadastrarUsuario">Salvar</button>
                <button class="btn btn-outline-secondary" @onclick="() => { mostrarFormulario = false; mensagem = null; }">Cancelar</button>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-royal">
                <tr>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Perfil</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usuario in usuarios)
                {
                    <tr>
                        <td>@usuario.Nome</td>
                        <td>@usuario.Email</td>
                        <td><span class="badge bg-royal">@usuario.Perfil</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool mostrarFormulario = false;
    private string? mensagem;
    private UsuarioMock novoUsuario = new();

    // TODO: substituir por chamada real ao endpoint de usuários
    private List<UsuarioMock> usuarios = [
        new() { Nome = "João Silva", Email = "joao@email.com", Perfil = "Vendedor" },
        new() { Nome = "Maria Souza", Email = "maria@email.com", Perfil = "Admin" },
    ];

    private void CadastrarUsuario()
    {
        // TODO: integrar com endpoint de cadastro de usuários
        usuarios.Add(new UsuarioMock
        {
            Nome = novoUsuario.Nome,
            Email = novoUsuario.Email,
            Perfil = novoUsuario.Perfil
        });
        mensagem = $"Usuário \"{novoUsuario.Nome}\" cadastrado como {novoUsuario.Perfil}!";
        novoUsuario = new();
    }

    private class UsuarioMock
    {
        public string Nome { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Perfil { get; set; } = string.Empty;
    }
}
