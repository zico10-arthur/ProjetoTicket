@page "/"
@layout PublicLayout
@inject BlazorFront.Services.EventoService EventoService

<PageTitle>Sold Out Tickets</PageTitle>

<div class="container pb-5 pt-4">
    @if (loading)
    {
        <p class="text-center text-muted">Carregando eventos...</p>
    }
    else if (erro != null)
    {
        <div class="alert alert-danger text-center">@erro</div>
    }
    else if (!eventos.Any())
    {
        <p class="text-center text-muted">Nenhum evento disponível no momento.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var evento in eventos)
            {
                <div class="col">
                    <div class="card evento-card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title text-royal fw-bold">@evento.Nome</h5>
                            <hr class="border-royal" />
                            <p class="mb-1">
                                <span class="evento-label">📅 Data</span>
                                <span>@evento.DataEvento.ToString("dd/MM/yyyy")</span>
                            </p>
                            <p class="mb-1">
                                <span class="evento-label">👥 Capacidade</span>
                                <span>@evento.CapacidadeTotal pessoas</span>
                            </p>
                            <p class="mb-0">
                                <span class="evento-label">💰 Preço</span>
                                <span class="fw-bold text-royal">R$ @evento.PrecoPadrao.ToString("F2")</span>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<BlazorFront.Models.EventoModel> eventos = [];
    private bool loading = true;
    private string? erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eventos = await EventoService.GetAllAsync();
        }
        catch
        {
            erro = "Não foi possível carregar os eventos.";
        }
        finally
        {
            loading = false;
        }
    }
}
