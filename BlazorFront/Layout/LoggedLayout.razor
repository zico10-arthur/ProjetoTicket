@inherits LayoutComponentBase

<div class="public-page">
    <header class="public-header px-4 py-3 d-flex justify-content-between align-items-center">
        <span class="fw-bold fs-5">🎟️ Sold Out Tickets</span>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small">@Perfil</span>
            <a href="/login" class="btn btn-outline-light btn-sm px-4">Sair</a>
        </div>
    </header>

    <main class="public-content">
        @Body
    </main>
</div>

@code {
    // TODO: substituir pelo perfil real vindo do AuthService após integração do login
    [Parameter] public string Perfil { get; set; } = string.Empty;
}
