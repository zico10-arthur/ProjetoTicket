@page "/cadastro"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-8">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">Cadastro</MudText>

        @if (!string.IsNullOrEmpty(mensagemSucesso))
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@mensagemSucesso</MudAlert>
        }
        @if (!string.IsNullOrEmpty(mensagemErro))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@mensagemErro</MudAlert>
        }

        <MudTextField @bind-Value="nome" Label="Nome" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="cpf" Label="CPF" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="email" Label="E-mail" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="senha" Label="Senha" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-6" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="Cadastrar" Disabled="carregando">
            @if (carregando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Cadastrar
        </MudButton>

        <MudText Align="Align.Center" Class="mt-4">
            Já tem conta? <MudLink Href="/login">Entrar</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    string nome = string.Empty;
    string cpf = string.Empty;
    string email = string.Empty;
    string senha = string.Empty;
    string mensagemSucesso = string.Empty;
    string mensagemErro = string.Empty;
    bool carregando = false;

    record ErroResponse(string Message);

    async Task Cadastrar()
    {
        mensagemSucesso = string.Empty;
        mensagemErro = string.Empty;
        carregando = true;

        var client = HttpClientFactory.CreateClient("Api");
        var response = await client.PostAsJsonAsync("/api/Usuario/CadastrarComprador", new
        {
            Cpf = cpf,
            Nome = nome,
            Email = email,
            Senha = senha
        });

        carregando = false;

        if (response.IsSuccessStatusCode)
        {
            mensagemSucesso = "Usuário cadastrado com sucesso!";
            Nav.NavigateTo("/login");
        }
        else
        {
            var erro = await response.Content.ReadFromJsonAsync<ErroResponse>();
            mensagemErro = erro?.Message ?? "Erro ao cadastrar.";
        }
    }
}
